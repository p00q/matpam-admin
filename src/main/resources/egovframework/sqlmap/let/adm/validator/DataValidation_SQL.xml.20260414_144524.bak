<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="egovframework.let.adm.validator.service.impl.DataValidationMapper">

    <!--
        주문-주문항목 금액 불일치 목록 조회
        - 권장안에 따라 기간 조회(WHERE O.ORDER_DATE)를 필수로 적용합니다.
    -->
    <select id="selectMismatchedOrderList" parameterType="egovframework.let.adm.validator.service.OrderValidationSearchVO" resultType="egovframework.let.adm.validator.service.OrderValidationResultVO">
        SELECT
            T.orderId,
            T.orderTotalPrice,
            T.itemAmountSum
        FROM (
            SELECT
                O.ORDER_ID              AS orderId,
                O.TOTAL_PRICE           AS orderTotalPrice,
                OI_SUM.CALCULATED_PRICE AS itemAmountSum,
                ROW_NUMBER() OVER (ORDER BY O.ORDER_ID DESC) AS RNUM
            FROM
                ORDERS O
            INNER JOIN (
                SELECT
                    ORDER_ID,
                    SUM(PRICE * QUANTITY) AS CALCULATED_PRICE
                FROM
                    ORDER_ITEMS
                GROUP BY
                    ORDER_ID
            ) OI_SUM ON O.ORDER_ID = OI_SUM.ORDER_ID
            WHERE
                O.TOTAL_PRICE != OI_SUM.CALCULATED_PRICE
                AND O.ORDER_DATE BETWEEN TO_DATE(#{searchStartDate}, 'YYYY-MM-DD') AND (TO_DATE(#{searchEndDate}, 'YYYY-MM-DD') + 1 - 0.00001)
        ) T
        WHERE
            T.RNUM BETWEEN #{firstIndex} AND #{lastIndex}
    </select>

    <!--
        주문-주문항목 금액 불일치 목록 총 건수 조회 (페이징 처리용)
    -->
    <select id="selectMismatchedOrderListTotCnt" parameterType="egovframework.let.adm.validator.service.OrderValidationSearchVO" resultType="int">
        SELECT
            COUNT(*)
        FROM
            ORDERS O
        INNER JOIN (
            SELECT
                ORDER_ID,
                SUM(PRICE * QUANTITY) AS CALCULATED_PRICE
            FROM
                ORDER_ITEMS
            GROUP BY
                ORDER_ID
        ) OI_SUM ON O.ORDER_ID = OI_SUM.ORDER_ID
        WHERE
            O.TOTAL_PRICE != OI_SUM.CALCULATED_PRICE
            AND O.ORDER_DATE BETWEEN TO_DATE(#{searchStartDate}, 'YYYY-MM-DD') AND (TO_DATE(#{searchEndDate}, 'YYYY-MM-DD') + 1 - 0.00001)
    </select>

</mapper>