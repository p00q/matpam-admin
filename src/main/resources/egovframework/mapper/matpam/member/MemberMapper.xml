<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="matpam.member.MemberMapper">

    <!-- [MemberMapper.xml] 매핑 하드닝 및 바인딩 무결성 복구 (Universal) -->
    <resultMap id="memberResultMap" type="kr.co.matpam.admin.member.service.MemberVO">
        <id property="memberPk"           column="MEMBER_ID"/>
        <result property="memberNo"       column="MEMBER_ID"/>
        <result property="memberId"       column="LOGIN_ID"/>
        <result property="loginId"        column="LOGIN_ID"/>
        <result property="companyName"    column="COMPANY_NAME"/>
        <result property="ceoName"        column="CEO_NAME"/>
        <result property="businessNumber" column="BIZ_REG_NO"/>
        <result property="memberType"     column="MEMBER_TYPE_CD"/>
        <result property="memberTypeName" column="MEMBER_TYPE_NAME"/>
        <result property="memberGrade"    column="MEMBER_GRADE_CD"/>
        <result property="memberGradeName" column="MEMBER_GRADE_NAME"/>
        <result property="status"         column="JOIN_STATUS_CD"/>
        <result property="statusName"     column="JOIN_STATUS_NAME"/>
        <result property="joinDate"       column="JOIN_DT"/>
        <result property="useYn"          column="USE_YN"/>
        <result property="opType"         column="OP_TYPE"/>
        <result property="deliveryTypeCd" column="DELIVERY_TYPE_CD"/>
        <result property="deliveryTypeName" column="DELIVERY_TYPE_NAME"/>
        <result property="managerName"    column="MANAGER_NAME"/>
        <result property="managerContact" column="MANAGER_CONTACT"/>
    </resultMap>

    <!-- 판매자 목록 조회 (구성상품 관리 드롭다운용) - 필터링 완화 및 컬럼 전수 대문자 매핑 -->
    <select id="selectSellerList" resultMap="memberResultMap">
        SELECT 
            MEMBER_ID, LOGIN_ID, COMPANY_NAME, CEO_NAME, BIZ_REG_NO, MEMBER_TYPE_CD, USE_YN, OP_TYPE
        FROM tb_member
        WHERE DEL_YN = 'N'
          AND (
               MEMBER_TYPE_CD IN ('SELLER', 'PROVIDER', 'VENDOR')
               OR MEMBER_TYPE_CD LIKE '%SELLER%'
               OR MEMBER_TYPE_CD LIKE '%PROVIDER%'
               OR MEMBER_TYPE_CD LIKE '%VENDOR%'
          )
        ORDER BY COMPANY_NAME ASC
    </select>

    <select id="selectMemberList" parameterType="kr.co.matpam.admin.member.service.MemberDefaultVO" resultMap="memberResultMap">
        SELECT m.* FROM tb_member m WHERE m.DEL_YN = 'N' ORDER BY m.MEMBER_ID DESC
        <include refid="kr.co.matpam.common.mapper.MatpamCommonMapper.pagingFooter"/>
    </select>
    
    <select id="selectMemberListTotCnt" parameterType="kr.co.matpam.admin.member.service.MemberDefaultVO" resultType="int">
        SELECT COUNT(*) FROM tb_member m WHERE m.DEL_YN = 'N'
    </select>
    
    <select id="selectMember" parameterType="kr.co.matpam.admin.member.service.MemberVO" resultMap="memberResultMap">
        SELECT * FROM tb_member WHERE MEMBER_ID = #{memberNo} AND DEL_YN = 'N'
    </select>
    
    <insert id="insertMember" parameterType="kr.co.matpam.admin.member.service.MemberVO">
        INSERT INTO tb_member (MEMBER_TYPE_CD, LOGIN_ID, LOGIN_PWD, COMPANY_NAME, CEO_NAME, REG_ID, REG_DT)
        VALUES (#{memberType}, #{loginId}, #{loginPw}, #{companyName}, #{ceoName}, 'SYSTEM', NOW())
        <selectKey keyProperty="memberNo" resultType="long" order="AFTER">
            SELECT LAST_INSERT_ID()
        </selectKey>
    </insert>
</mapper>
