<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kr.co.matpam.admin.product.service.impl.ProductMapper">

    <resultMap id="productResultMap" type="kr.co.matpam.admin.product.service.ProductVO">
        <id property="productNo" column="PRODUCT_NO"/>
        <result property="productName" column="PRODUCT_NAME"/>
        <result property="salePrice" column="SALE_PRICE"/>
        <result property="costPrice" column="COST_PRICE"/>
        <result property="vatAmount" column="VAT_AMOUNT"/>
        <result property="saleStartDate" column="SALE_START_DATE"/>
        <result property="saleEndDate" column="SALE_END_DATE"/>
        <result property="displayYn" column="DISPLAY_YN"/>
        <result property="sellerId" column="SELLER_ID"/>
        <result property="productSummary" column="PRODUCT_SUMMARY"/>
        <result property="regDt" column="REG_DT"/>
        <result property="modDt" column="MOD_DT"/>
        <!-- 조회수, 주문수 등은 별도 테이블 조인 필요하나 현재는 컬럼 없음 or 임시 -->
    </resultMap>

    <sql id="selectProductListWhere">
        <where>
            <if test="searchKeyword != null and searchKeyword != ''">
                AND PRODUCT_NAME LIKE CONCAT('%', #{searchKeyword}, '%')
            </if>
            <if test="displayYn != null and displayYn != ''">
                AND DISPLAY_YN = #{displayYn}
            </if>
            <!-- 기간 검색 등 추가 가능 -->
        </where>
    </sql>

    <!-- 상품 목록 조회 -->
    <select id="selectProductList" parameterType="kr.co.matpam.admin.product.service.ProductVO" resultMap="productResultMap">
        SELECT
            A.PRODUCT_NO,
            A.PRODUCT_NAME,
            A.SALE_PRICE,
            A.COST_PRICE,
            A.VAT_AMOUNT,
            A.SALE_START_DATE,
            A.SALE_END_DATE,
            A.DISPLAY_YN,
            A.SELLER_ID,
            A.REG_DT,
            A.MOD_DT
        FROM TB_PRODUCT A
        <include refid="selectProductListWhere"/>
        ORDER BY A.PRODUCT_NO DESC
        LIMIT #{recordCountPerPage} OFFSET #{firstIndex}
    </select>

    <!-- 상품 목록 총 개수 -->
    <select id="selectProductListTotCnt" parameterType="kr.co.matpam.admin.product.service.ProductVO" resultType="int">
        SELECT COUNT(*)
        FROM TB_PRODUCT A
        <include refid="selectProductListWhere"/>
    </select>

</mapper>
