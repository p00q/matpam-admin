<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.co.matpam.admin.product.service.impl.SalesProductMapper">

    <!-- =========================================================
         ResultMap : tb_sales_product
         - SalesProductVO 기준
         ========================================================= -->
    <resultMap id="salesProductResultMap" type="kr.co.matpam.admin.product.service.SalesProductVO">
        <id     property="salesProdId"       column="SALES_PROD_ID"/>
        <result property="salesProdCode"     column="SALES_PROD_CODE"/>
        <result property="salesProdName"     column="SALES_PROD_NAME"/>

        <result property="sellerMemberId"    column="SELLER_MEMBER_ID"/>
        <result property="sellerName"        column="SELLER_NAME"/>

        <result property="listPrice"         column="LIST_PRICE"/>
        <result property="salePrice"         column="SALE_PRICE"/>
        <result property="costPrice"         column="COST_PRICE"/>
        <result property="vatRate"           column="VAT_RATE"/>

        <result property="exposureStatusCd"  column="EXPOSURE_STATUS_CD"/>
        <result property="saleStatusCd"      column="SALE_STATUS_CD"/>

        <result property="saleStartDt"       column="SALE_START_DT"/>
        <result property="saleEndDt"         column="SALE_END_DT"/>

        <result property="viewCnt"           column="VIEW_CNT"/>
        <result property="summary"           column="SUMMARY"/>
        <result property="mdComment"         column="MD_COMMENT"/>

        <result property="detailHtml"        column="DETAIL_HTML"/>
        <result property="paymentInfo"       column="PAYMENT_INFO"/>
        <result property="deliveryInfo"      column="DELIVERY_INFO"/>
        <result property="returnInfo"        column="RETURN_INFO"/>
        <result property="refundInfo"        column="REFUND_INFO"/>

        <result property="useYn"             column="USE_YN"/>
        <result property="delYn"             column="DEL_YN"/>
        <result property="opType"            column="OP_TYPE"/>
        <result property="discountAmt"      column="DISCOUNT_AMT"/>
        <result property="vatYn"            column="VAT_YN"/>
        <result property="vatAmount"        column="VAT_AMOUNT"/>

        <result property="regId"             column="REG_ID"/>
        <result property="regDt"             column="REG_DT"/>
        <result property="modId"             column="MOD_ID"/>
        <result property="modDt"             column="MOD_DT"/>
    </resultMap>

    <!-- =========================================================
         WHERE 조건 공통
         ========================================================= -->
    <sql id="salesProductWhere">
        <where>
            <choose>
                <when test="delYn != null and delYn != ''">
                    AND sp.DEL_YN = #{delYn}
                </when>
                <otherwise>
                    AND sp.DEL_YN = 'N'
                </otherwise>
            </choose>

            <if test="useYn != null and useYn != ''">
                AND sp.USE_YN = #{useYn}
            </if>

            <if test="sellerMemberId != null">
                AND sp.SELLER_MEMBER_ID = #{sellerMemberId}
            </if>

            <if test="exposureStatusCd != null and exposureStatusCd != ''">
                AND sp.EXPOSURE_STATUS_CD = #{exposureStatusCd}
            </if>

            <if test="saleStatusCd != null and saleStatusCd != ''">
                AND sp.SALE_STATUS_CD = #{saleStatusCd}
            </if>

            <if test="searchKeyword != null and searchKeyword != ''">
                AND (
                    sp.SALES_PROD_NAME LIKE CONCAT('%', #{searchKeyword}, '%')
                    OR sp.SALES_PROD_CODE LIKE CONCAT('%', #{searchKeyword}, '%')
                )
            </if>

            <!-- 운영 타입 기반 데이터 격리 (sp. 별칭 직접 명시) -->
            <if test="opType != null and opType != '' and opType != 'NATIONAL'">
                AND sp.op_type = #{opType}
            </if>
        </where>
    </sql>

    <!-- =========================================================
         판매상품 목록 조회
         ========================================================= -->
    <select id="selectSalesProductList"
            parameterType="kr.co.matpam.admin.product.service.SalesProductVO"
            resultMap="salesProductResultMap">
        SELECT
            sp.SALES_PROD_ID,
            sp.SALES_PROD_CODE,
            sp.SALES_PROD_NAME,

            sp.SELLER_MEMBER_ID,
            m.company_name AS SELLER_NAME,

            sp.LIST_PRICE,
            sp.SALE_PRICE,
            CAST(sp.COST_PRICE AS DECIMAL(18,0)) AS COST_PRICE,
            sp.VAT_RATE,

            sp.EXPOSURE_STATUS_CD,
            sp.SALE_STATUS_CD,
            sp.SALE_START_DT,
            sp.SALE_END_DT,

            sp.VIEW_CNT,
            sp.SUMMARY,
            sp.MD_COMMENT,

            sp.USE_YN,
            sp.DEL_YN,
            sp.OP_TYPE,
            sp.DISCOUNT_AMT,
            sp.VAT_YN,

            sp.REG_ID,
            sp.REG_DT,
            sp.MOD_ID,
            sp.MOD_DT
        FROM tb_sales_product sp
        LEFT JOIN tb_member_master m
            ON sp.SELLER_MEMBER_ID = m.member_id
        <include refid="salesProductWhere"/>
        ORDER BY sp.SALES_PROD_ID DESC
        <include refid="kr.co.matpam.common.mapper.MatpamCommonMapper.pagingFooter"/>
    </select>

    <!-- =========================================================
         판매상품 목록 총 건수
         ========================================================= -->
    <select id="selectSalesProductListTotCnt"
            parameterType="kr.co.matpam.admin.product.service.SalesProductVO"
            resultType="int">
        SELECT COUNT(1)
        FROM tb_sales_product sp
        <include refid="salesProductWhere"/>
    </select>

    <!-- =========================================================
         판매상품 상세 조회
         ========================================================= -->
    <select id="selectSalesProduct"
            parameterType="kr.co.matpam.admin.product.service.SalesProductVO"
            resultMap="salesProductResultMap">
        SELECT
            sp.SALES_PROD_ID,
            sp.SALES_PROD_CODE,
            sp.SALES_PROD_NAME,

            sp.SELLER_MEMBER_ID,
            m.company_name AS SELLER_NAME,

            spd.DETAIL_HTML,
            spd.PAYMENT_INFO,
            spd.DELIVERY_INFO,
            spd.RETURN_INFO,
            spd.REFUND_INFO,

            sp.LIST_PRICE,
            sp.SALE_PRICE,
            CAST(sp.COST_PRICE AS DECIMAL(18,0)) AS COST_PRICE,
            sp.VAT_RATE,

            sp.EXPOSURE_STATUS_CD,
            sp.SALE_STATUS_CD,
            sp.SALE_START_DT,
            sp.SALE_END_DT,

            sp.VIEW_CNT,
            sp.SUMMARY,
            sp.MD_COMMENT,


            sp.USE_YN,
            sp.DEL_YN,
            sp.DISCOUNT_AMT,
            sp.VAT_YN,
            sp.OP_TYPE,

            sp.REG_ID,
            sp.REG_DT,
            sp.MOD_ID,
            sp.MOD_DT
        FROM tb_sales_product sp
        LEFT JOIN tb_member_master m
            ON sp.SELLER_MEMBER_ID = m.member_id
        LEFT JOIN tb_sales_product_detail spd
            ON sp.SALES_PROD_ID = spd.SALES_PROD_ID
           AND spd.DEL_YN = 'N'
        WHERE sp.SALES_PROD_ID = #{salesProdId}
          AND sp.DEL_YN = 'N'
        <if test="opType != null and opType != '' and opType != 'NATIONAL'">
            AND sp.op_type = #{opType}
        </if>
    </select>

    <!-- =========================================================
         판매상품 등록
         ========================================================= -->
    <insert id="insertSalesProduct"
            parameterType="kr.co.matpam.admin.product.service.SalesProductVO"
            useGeneratedKeys="true"
            keyProperty="salesProdId">
        INSERT INTO tb_sales_product (
            sales_prod_code,
            sales_prod_name,
            seller_member_id,

            LIST_PRICE,
            SALE_PRICE,
            COST_PRICE,
            VAT_RATE,

            EXPOSURE_STATUS_CD,
            SALE_STATUS_CD,
            SALE_START_DT,
            SALE_END_DT,

            VIEW_CNT,
            SUMMARY,
            MD_COMMENT,

            USE_YN,
            DEL_YN,
            OP_TYPE,
            DISCOUNT_AMT,
            VAT_YN,

            REG_ID,
            REG_DT,
            MOD_ID,
            MOD_DT
        ) VALUES (
            <choose>
                <when test="salesProdCode != null and salesProdCode != ''">
                    #{salesProdCode}
                </when>
                <otherwise>
                    CONCAT('SP', DATE_FORMAT(NOW(), '%Y%m%d%H%i%s'), LPAD(FLOOR(RAND()*1000), 3, '0'))
                </otherwise>
            </choose>,
            #{salesProdName},
            #{sellerMemberId},

            #{listPrice},
            #{salePrice},
            #{costPrice},
            #{vatRate},

            COALESCE(#{exposureStatusCd}, 'Y'),
            COALESCE(#{saleStatusCd}, 'LIVE'),
            #{saleStartDt},
            #{saleEndDt},

            0,
            #{summary},
            #{mdComment},

            #{useYn},
            'N',
            #{opType},
            #{discountAmt},
            #{vatYn},

            #{regId},
            NOW(),
            #{modId},
            NOW()
        )
    </insert>

    <!-- =========================================================
         판매상품 수정
         ========================================================= -->
    <update id="updateSalesProduct"
            parameterType="kr.co.matpam.admin.product.service.SalesProductVO">
        UPDATE tb_sales_product
        SET
            sales_prod_name      = #{salesProdName},
            seller_member_id     = #{sellerMemberId},

            LIST_PRICE           = #{listPrice},
            SALE_PRICE           = #{salePrice},
            COST_PRICE           = #{costPrice},
            VAT_RATE             = #{vatRate},

            EXPOSURE_STATUS_CD   = COALESCE(#{exposureStatusCd}, 'Y'),
            SALE_STATUS_CD       = COALESCE(#{saleStatusCd}, 'LIVE'),
            SALE_START_DT        = #{saleStartDt},
            SALE_END_DT          = #{saleEndDt},

            SUMMARY              = #{summary},
            MD_COMMENT           = #{mdComment},

            USE_YN               = #{useYn},
            DISCOUNT_AMT         = #{discountAmt},
            VAT_YN               = #{vatYn},

            MOD_ID               = #{modId},
            MOD_DT               = NOW()
        WHERE sales_prod_id = #{salesProdId}
          AND del_yn = 'N'
        <if test="opType != null and opType != '' and opType != 'NATIONAL'">
            AND op_type = #{opType}
        </if>
    </update>

    <!-- =========================================================
         판매상품 상세(설명/정책) 저장 (UPSERT)
         ========================================================= -->
    <insert id="upsertSalesProductDetail"
            parameterType="kr.co.matpam.admin.product.service.SalesProductVO">
        INSERT INTO tb_sales_product_detail (
            sales_prod_id,
            detail_html,
            PAYMENT_INFO,
            DELIVERY_INFO,
            RETURN_INFO,
            REFUND_INFO,

            USE_YN,
            DEL_YN,

            REG_ID,
            REG_DT,
            MOD_ID,
            MOD_DT
        ) VALUES (
            #{salesProdId},
            #{detailHtml},
            #{paymentInfo},
            #{deliveryInfo},
            #{returnInfo},
            #{refundInfo},

            COALESCE(#{useYn}, 'Y'),
            'N',

            COALESCE(#{regId}, 'SYSTEM'),
            NOW(),
            COALESCE(#{modId}, COALESCE(#{regId}, 'SYSTEM')),
            NOW()
        )
        ON DUPLICATE KEY UPDATE
            DETAIL_HTML   = VALUES(DETAIL_HTML),
            PAYMENT_INFO  = VALUES(PAYMENT_INFO),
            DELIVERY_INFO = VALUES(DELIVERY_INFO),
            RETURN_INFO   = VALUES(RETURN_INFO),
            REFUND_INFO   = VALUES(REFUND_INFO),

            USE_YN = VALUES(USE_YN),
            MOD_ID = VALUES(MOD_ID),
            MOD_DT = NOW()
    </insert>

    <!-- =========================================================
         판매상품 삭제(논리삭제)
         ========================================================= -->
    <update id="deleteSalesProduct" parameterType="kr.co.matpam.admin.product.service.SalesProductVO">
        UPDATE tb_sales_product sp
        SET
            DEL_YN = 'Y',
            MOD_DT = NOW()
        WHERE sp.SALES_PROD_ID = #{salesProdId}
          <if test="opType != null and opType != '' and opType != 'NATIONAL'">
              AND sp.op_type = #{opType}
          </if>
    </update>

    <!-- =========================================================
         조회수 증가
         ========================================================= -->
    <update id="increaseViewCount" parameterType="kr.co.matpam.admin.product.service.SalesProductVO">
        UPDATE tb_sales_product sp
        SET VIEW_CNT = COALESCE(VIEW_CNT, 0) + 1,
            MOD_DT = NOW()
        WHERE sp.SALES_PROD_ID = #{salesProdId}
          AND sp.DEL_YN = 'N'
          <if test="opType != null and opType != '' and opType != 'NATIONAL'">
              AND sp.op_type = #{opType}
          </if>
    </update>

    <!-- =========================================================
         판매상품 이미지 등록
         ========================================================= -->
    <insert id="insertSalesProductImage"
            parameterType="kr.co.matpam.admin.product.service.SalesProductImageVO">
        INSERT INTO tb_sales_product_image (
            sales_prod_id,
            img_url,
            SORT_ORDER,
            IS_MAIN_YN,
            REG_ID,
            REG_DT,
            MOD_ID,
            MOD_DT
        ) VALUES (
            #{salesProdId},
            #{imgUrl},
            #{sortOrder},
            #{isMainYn},
            #{regId},
            NOW(),
            #{modId},
            NOW()
        )
    </insert>

    <!-- =========================================================
         판매상품 이미지 삭제 (관리용-전체 삭제)
         ========================================================= -->
    <delete id="deleteSalesProductImages" parameterType="kr.co.matpam.admin.product.service.SalesProductVO">
        DELETE i FROM tb_sales_product_image i
        INNER JOIN tb_sales_product sp ON i.sales_prod_id = sp.SALES_PROD_ID
        WHERE i.SALES_PROD_ID = #{salesProdId}
          <if test="opType != null and opType != '' and opType != 'NATIONAL'">
              AND sp.op_type = #{opType}
          </if>
    </delete>

    <!-- =========================================================
         판매상품 이미지 목록 조회
         ========================================================= -->
    <select id="selectSalesProductImageList" parameterType="kr.co.matpam.admin.product.service.SalesProductVO" resultType="kr.co.matpam.admin.product.service.SalesProductImageVO">
        SELECT
            i.SALES_PROD_IMAGE_ID AS salesProdImageId,
            i.SALES_PROD_ID AS salesProdId,
            i.IMG_URL AS imgUrl,
            i.SORT_ORDER AS sortOrder,
            i.IS_MAIN_YN AS isMainYn
        FROM tb_sales_product_image i
        INNER JOIN tb_sales_product sp ON i.sales_prod_id = sp.SALES_PROD_ID
        WHERE i.SALES_PROD_ID = #{salesProdId}
          <if test="opType != null and opType != '' and opType != 'NATIONAL'">
              AND sp.op_type = #{opType}
          </if>
        ORDER BY i.SORT_ORDER ASC
    </select>

</mapper>
