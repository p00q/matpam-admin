<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kr.co.matpam.admin.user.service.impl.UserMapper">

    <resultMap id="userMap" type="kr.co.matpam.admin.user.service.UserVO">
        <id property="userId" column="user_id"/>
        <result property="tenantId" column="tenant_id"/>
        <result property="companyId" column="company_id"/>
        <result property="loginId" column="login_id"/>
        <result property="passwordHash" column="password_hash"/>
        <result property="userName" column="user_name"/>
        <result property="mobile" column="mobile"/>
        <result property="email" column="email"/>
        <result property="userRole" column="user_role"/>
        <result property="channelId" column="channel_id"/>
        <result property="status" column="status"/>
        <result property="lastLoginAt" column="last_login_at"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="userWhere">
        <where>
            <if test="tenantId != null">
                AND tenant_id = #{tenantId}
            </if>
            <if test="companyId != null">
                AND company_id = #{companyId}
            </if>
            <if test="userRole != null and userRole != ''">
                AND user_role = #{userRole}
            </if>
            <if test="channelId != null">
                AND channel_id = #{channelId}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="searchKeyword != null and searchKeyword != ''">
                AND (login_id LIKE CONCAT('%', #{searchKeyword}, '%') OR user_name LIKE CONCAT('%', #{searchKeyword}, '%'))
            </if>
        </where>
    </sql>

    <select id="selectUserList" parameterType="kr.co.matpam.admin.user.service.UserVO" resultMap="userMap">
        SELECT * FROM tb_user
        <include refid="userWhere"/>
        ORDER BY created_at DESC
        LIMIT #{recordCountPerPage} OFFSET #{firstIndex}
    </select>

    <select id="selectUserListTotCnt" parameterType="kr.co.matpam.admin.user.service.UserVO" resultType="int">
        SELECT COUNT(*) FROM tb_user
        <include refid="userWhere"/>
    </select>

    <select id="selectUserDetail" parameterType="kr.co.matpam.admin.user.service.UserVO" resultMap="userMap">
        SELECT * FROM tb_user WHERE user_id = #{userId}
    </select>

    <select id="selectUserByLoginId" parameterType="string" resultMap="userMap">
        SELECT * FROM tb_user WHERE login_id = #{loginId}
    </select>

    <insert id="insertUser" parameterType="kr.co.matpam.admin.user.service.UserVO" useGeneratedKeys="true" keyProperty="userId">
        INSERT INTO tb_user (
            tenant_id, company_id, login_id, password_hash, user_name,
            mobile, email, user_role, channel_id, status
        ) VALUES (
            #{tenantId}, #{companyId}, #{loginId}, #{passwordHash}, #{userName},
            #{mobile}, #{email}, #{userRole}, #{channelId}, 'ACTIVE'
        )
    </insert>

    <update id="updateUser" parameterType="kr.co.matpam.admin.user.service.UserVO">
        UPDATE tb_user
        SET
            user_name = #{userName},
            mobile = #{mobile},
            email = #{email},
            user_role = #{userRole},
            channel_id = #{channelId},
            updated_at = NOW()
        WHERE user_id = #{userId}
    </update>

    <update id="updateUserStatus" parameterType="kr.co.matpam.admin.user.service.UserVO">
        UPDATE tb_user
        SET status = #{status}, updated_at = NOW()
        WHERE user_id = #{userId}
    </update>

</mapper>
